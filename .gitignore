# ─────────────────────────────────────────────────────────────────────────────
# CircleGuard — root .gitignore
# Covers: Java/Kotlin/Gradle, Python, Node/Expo, Docker, Kubernetes/Helm,
# Terraform, IDEs, OS junk, secrets, test/coverage artifacts, AI assistants.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Browser-automation debug artefacts ──────────────────────────────────────
.playwright-mcp/

# ─── Secrets / environment ───────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
*.jks
!**/src/**/*.jks
*.crt
!**/src/**/*.crt
secrets/
.secrets/
credentials.json
service-account*.json
gcp-key*.json
azure-credentials*.json
kubeconfig
kubeconfig.*
*.kubeconfig

# ─── Gradle / Java / Kotlin ──────────────────────────────────────────────────
.gradle/
build/
!**/src/**/build/
**/build/
!gradle-wrapper.jar
out/
bin/
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.tar.bz2
*.tgz
*.rar
*.7z
hs_err_pid*
replay_pid*

# Maven (if any submodule uses it)
target/
**/target/
.mvn/wrapper/maven-wrapper.jar
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

