.expo-shared/
dist/
web-build/
.next/
.nuxt/
.parcel-cache/
.turbo/
.vite/
.svelte-kit/
.cache/

# React Native
android/.gradle/
android/app/build/
ios/build/
ios/Pods/
ios/DerivedData/

# ─── Docker ──────────────────────────────────────────────────────────────────
