.nox/
.hypothesis/
nosetests.xml
.cache/
*.egg-info/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.python-version
Pipfile.lock
poetry.lock
uv.lock

# Virtualenvs (cover all the variants in this repo)
.venv/
.venv-*/
venv/
env/
ENV/
.virtualenv/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

