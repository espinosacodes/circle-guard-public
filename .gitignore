charts/*.tgz
*.tgz
**/charts/*.tgz
**/charts/
!**/Chart.yaml
!**/values.yaml
!**/templates/
*-secret.yaml
*-secret.yml
sealed-secret-*.yaml
.helm/
kustomization.local.yaml

# ─── Terraform ───────────────────────────────────────────────────────────────
infra/terraform/**/.terraform/
infra/terraform/**/.terraform.lock.hcl
infra/terraform/**/terraform.tfstate
infra/terraform/**/terraform.tfstate.*
